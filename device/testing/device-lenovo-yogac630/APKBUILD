# Reference: <https://postmarketos.org/devicepkg>
pkgname=device-lenovo-yogac630
pkgdesc="Lenovo Yoga C630"
pkgver=0.1
pkgrel=13
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
# pmb:strict: avoid grub-related install error during build with pmbootstrap
options="!check !archcheck pmb:strict"
depends="postmarketos-base
	linux-postmarketos-qcom-sdm845
	soc-qcom-sdm845"
makedepends="devicepkg-dev grub grub-efi"
subpackages="$pkgname-nonfree-firmware:nonfree_firmware"
source="
	deviceinfo
	grub.cfg
	"

build() {
	devicepkg_build $startdir $pkgname

	# --config="$srcdir/grub_early.cfg"
	grub-mkimage \
		--prefix="/grub" \
		--output="bootaa64.efi" \
		--format="arm64-efi" \
		--compression="xz" \
		\
		all_video \
		cat \
		configfile \
		disk \
		echo \
		efi_gop \
		fat \
		gzio \
		help \
		iso9660 \
		linux \
		ls \
		normal \
		part_gpt \
		part_msdos \
		search \
		search_label \
		test \
		true
}

package() {
	devicepkg_package $startdir $pkgname

	install -Dm644 "$srcdir"/bootaa64.efi \
		"$pkgdir"/boot/EFI/Boot/bootaa64.efi

	install -Dm644 "$srcdir"/grub.cfg \
		"$pkgdir"/boot/grub/grub.cfg
}

nonfree_firmware() {
	pkgdesc="Modem, WiFi, GPU and other device-specific firmware"
	depends="firmware-lenovo-yogac630 soc-qcom-sdm845-nonfree-firmware"
	mkdir "$subpkgdir"
}

