# Maintainer: Caleb Connolly <caleb@connolly.tech>

pkgname=firmware-lenovo-yogac630
pkgver=1
pkgrel=1
pkgdesc="Firmware for Lenovo Yoga C630"
url="https://gitlab.com/sdm845-mainline/firmware-lenovo-yogac630"
arch="aarch64"
depends="linux-firmware-qcom linux-firmware-ath10k"
license="proprietary"
options="!check !strip !archcheck !tracedeps pmb:cross-native"

_commit="02974cf95300d06fc2440fa8e36260ba3d59d641"

source="https://gitlab.com/sdm845-mainline/firmware-lenovo-yogac630/-/archive/$_commit/$pkgname-$_commit.tar.gz
	firmware.files
	30-gpu-firmware.files"
subpackages="
	$pkgname-initramfs:firmware_initramfs"

package() {
	for file in $(cat "$srcdir/firmware.files"); do
		install -Dm644 "$file" "$pkgdir/$file"
	done

	install -Dm644 "$srcdir/30-gpu-firmware.files" \
		"$subpkgdir/etc/postmarketos-mkinitfs/files/30-gpu-firmware.files"
}

firmware_initramfs() {
	pkgdesc="Files to be included in the initramfs to support osk-sdl"
	depends="$pkgname"
	install_if="$pkgname"
	mkdir "$subpkgdir"

	install -Dm644 "$srcdir/30-gpu-firmware.files" \
		"$subpkgdir/etc/postmarketos-mkinitfs/files/30-gpu-firmware.files"
}

