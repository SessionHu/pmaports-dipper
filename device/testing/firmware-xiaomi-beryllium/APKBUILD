pkgname=firmware-xiaomi-beryllium
pkgver=3
pkgrel=9
pkgdesc="Firmware for Xiaomi Poco F1"
url="https://gitlab.com/sdm845-mainline/firmware-xiaomi-beryllium"
arch="aarch64"
depends="
	soc-qcom-sdm845-nonfree-firmware linux-firmware-qcom linux-firmware-qca
	linux-firmware-ath10k firmware-xiaomi-beryllium-initramfs
"
license="proprietary"
options="!strip !check !archcheck"

_commit="aad74c8d4f6fb5852a20bebdebb2979ee63ed775"

source="
	$pkgname.tar.gz::$url/-/archive/$_commit/$pkgname-$_commit.tar.gz
	firmware.files
	30-gpu-firmware.files
"
	
subpackages="$pkgname-initramfs:firmware_initramfs"

package() {
	cd "$srcdir/$pkgname-$_commit/"
	while IFS="" read -r _i || [ -n "$_i" ]; do
		[ ! -d $(dirname $_i) ] && mkdir -p $(dirname $_i)
		echo $_i
		install -Dm644 $_i "$pkgdir/$_i"
	done < "$srcdir/firmware.files"
}

firmware_initramfs() {
	pkgdesc="Files to be included in the initramfs to support osk-sdl"
	depends="$pkgname"
	mkdir "$subpkgdir"

	install -Dm644 "$srcdir/30-gpu-firmware.files" \
		"$subpkgdir/etc/postmarketos-mkinitfs/files/30-gpu-firmware.files"
}

