pkgname=rrst
pkgdesc="postmarketOS boot splash screen"
pkgver=0.1.0
pkgrel=0
_commit="a50a26049400f460bb32b3e7df0d803a73fe90a9"
url="https://github.com/calebccff/rrst"
arch="all"
options="!check" # no testsuite
license="GPL-3.0"
source="$pkgname-$_commit.tar.gz::https://github.com/calebccff/rrst/archive/$_commit.tar.gz"
builddir="$srcdir/rrst-$_commit"
makedepends="meson inih-dev eudev-dev linux-headers"

build() {
	abuild-meson . output
	meson compile ${JOBS:+-j ${JOBS}} -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output

}

