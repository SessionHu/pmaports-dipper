pkgname=ufs-utils
pkgver=20210314
pkgrel=1
pkgdesc="Utilities to manage the UFS filesystem series"
url="https://github.com/westerndigitalcorporation/ufs-utils"
arch="all"
license="GPL-2.0-only"
depends=""
makedepends="libbsd-dev"
source="$pkgname-$pkgver.zip::https://github.com/westerndigitalcorporation/ufs-utils/archive/refs/heads/dev.zip"
builddir="$srcdir/ufs-utils-dev"
options="!check"

build() {
	make
}

package() {
	mkdir -p -v "$pkgdir/sbin"
	install -m0755 $pkgname "$pkgdir/sbin/ufs-utils"
}

