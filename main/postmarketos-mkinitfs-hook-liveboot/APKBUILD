# Contributor: Caleb Connolly <caleb@connolly.tech>
# Maintainer: Caleb Connolly <caleb@connolly.tech>
pkgname=postmarketos-mkinitfs-hook-liveboot
pkgver=1
pkgrel=25
pkgdesc="initfs hook to liveboot (from RAM) a rootfs"
url="https://postmarketos.org"
arch="all"
license="GPL-3.0-only"
depends="hkdm"
options="!check"
source="00-liveboot.sh
	user-confirm-copied.hkdm.toml
	30-liveboot.files"
builddir="$srcdir/"

package() {
	mkdir -p "$pkgdir"/etc/postmarketos-mkinitfs/hooks/
	install -Dm644 "$srcdir"/00-liveboot.sh \
		"$pkgdir"/etc/postmarketos-mkinitfs/hooks/
	install -Dm644 "$srcdir"/user-confirm-copied.hkdm.toml \
		"$pkgdir"/etc/hkdm/config.d/user-confirm.toml
	install -Dm644 "$srcdir"/30-liveboot.files \
		"$pkgdir"/etc/postmarketos-mkinitfs/files/30-liveboot.files
}

sha512sums="
