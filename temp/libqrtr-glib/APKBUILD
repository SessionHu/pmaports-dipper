# Forked from Alpine INSERT-REASON-HERE (CHANGEME!)

pkgname=libqrtr-glib
pkgver=1.1.0
pkgrel=0
pkgdesc="Qualcomm IPC Router protocol helper library"
url="https://gitlab.freedesktop.org/mobile-broadband/libqrtr-glib"
arch="all"
license="LGPL-2.1-or-later"
makedepends="glib-dev gtk-doc linux-headers autoconf-archive automake libtool"
subpackages="$pkgname-dev $pkgname-doc"
source="https://gitlab.freedesktop.org/mobile-broadband/libqrtr-glib/-/archive/master/libqrtr-glib-master.tar.gz"

builddir="$srcdir"/libqrtr-glib-master

build() {
	NOCONFIGURE=1 ./autogen.sh
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--localstatedir=/var \
		--disable-static \
		--enable-gtk-doc
	make
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" install
}

